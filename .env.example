# AI 密钥只能配置在后端运行环境，绝不能使用 NEXT_PUBLIC_ 前缀。
BIDRADAR_AI_API_KEY=
# 可选：同一服务商的后端备用凭据；主凭据失败时自动切换，不暴露给前端。
BIDRADAR_AI_SECONDARY_API_KEY=
BIDRADAR_AI_SECONDARY_MODEL=glm-5.2
BIDRADAR_AI_PROVIDER=zhipu
BIDRADAR_AI_MODEL=glm-4.7-flash
BIDRADAR_AI_FALLBACK_MODEL=glm-4.7-flash
BIDRADAR_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BIDRADAR_AI_ENABLED=auto
BIDRADAR_AI_TIMEOUT_SECONDS=35

# 飞书企业自建应用：定时任务只在发现新增或实质变化项目时写入多维表格。
# APP_SECRET、Webhook 等只允许放在后端环境变量，禁止使用 NEXT_PUBLIC_ 前缀。
BIDRADAR_FEISHU_ENABLED=auto
BIDRADAR_FEISHU_APP_ID=
BIDRADAR_FEISHU_APP_SECRET=
BIDRADAR_FEISHU_APP_TOKEN=
BIDRADAR_FEISHU_TABLE_ID=
# 必须是企业成员能访问的后端地址，用于生成 Word 下载链接；不要填 127.0.0.1。
BIDRADAR_PUBLIC_BASE_URL=
# 可选：写表成功后再向飞书群发送摘要通知。
BIDRADAR_FEISHU_WEBHOOK_URL=
BIDRADAR_FEISHU_WEBHOOK_SECRET=
BIDRADAR_FEISHU_TABLE_URL=
BIDRADAR_FEISHU_TIMEOUT_SECONDS=15
BIDRADAR_FEISHU_MAX_ATTEMPTS=10
# 可选：当现有列名不同，通过 JSON 覆盖逻辑字段到实际列名的映射。
# BIDRADAR_FEISHU_FIELD_MAP_JSON={"title":"标题","word_url":"Word"}
